# انسخ هذا الملف باسم .env واملأ القيم الحقيقية (لا ترفعه أبداً لأي مكان عام)

# رابط الاتصال بقاعدة بيانات PostgreSQL (من Railway)
DATABASE_URL=

# مفتاح الدخول للوحة تحكم الأدمن
ADMIN_KEY=

# وضع تطوير الـ OTP — يخلي كود التحقق يظهر بالشاشة بدل ما يرسل SMS حقيقي
# خليه true وحنا نجرب، وتذكر تحوله false قبل الإطلاق الحقيقي
OTP_DEV_MODE=true

PORT=3000
